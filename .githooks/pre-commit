#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python_bin="${PYTHON:-python3}"
if ! command -v "$python_bin" >/dev/null 2>&1; then
  python_bin="python"
fi

mapfile -d '' staged_files < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ "${#staged_files[@]}" -eq 0 ]]; then
  exit 0
fi

reject_path=0
large_file=0
python_files=()
shell_files=()

for path in "${staged_files[@]}"; do
  [[ -z "$path" ]] && continue

  case "$path" in
    data/raw/scraped/.gitkeep)
      ;;
    data/raw/scraped/*|outputs/*)
      echo "pre-commit: refusing to commit generated/raw artifact path: $path" >&2
      reject_path=1
      ;;
  esac

  if [[ -f "$path" ]]; then
    size_bytes="$(wc -c <"$path")"
    if [[ "$size_bytes" -gt 5242880 ]]; then
      echo "pre-commit: refusing to commit file larger than 5 MiB: $path ($size_bytes bytes)" >&2
      large_file=1
    fi
  fi

  case "$path" in
    *.py)
      python_files+=("$path")
      ;;
    *.sh|.githooks/*)
      shell_files+=("$path")
      ;;
  esac
done

if git diff --cached --check; then
  :
else
  echo "pre-commit: whitespace or conflict-marker issues detected" >&2
  exit 1
fi

if [[ "$reject_path" -ne 0 || "$large_file" -ne 0 ]]; then
  exit 1
fi

if [[ "${#python_files[@]}" -gt 0 ]]; then
  "$python_bin" -m py_compile "${python_files[@]}"
fi

if [[ "${#shell_files[@]}" -gt 0 ]]; then
  for path in "${shell_files[@]}"; do
    bash -n "$path"
  done
fi
