#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python_bin="${PYTHON:-python3}"
if ! command -v "$python_bin" >/dev/null 2>&1; then
  python_bin="python"
fi

mapfile -t python_files < <(git ls-files '*.py')
if [[ "${#python_files[@]}" -gt 0 ]]; then
  "$python_bin" -m py_compile "${python_files[@]}"
fi

mapfile -t shell_files < <(git ls-files '*.sh' '.githooks/*')
if [[ "${#shell_files[@]}" -gt 0 ]]; then
  for path in "${shell_files[@]}"; do
    bash -n "$path"
  done
fi

tracked_scraped="$(git ls-files 'data/raw/scraped/*' ':!data/raw/scraped/.gitkeep')"
if [[ -n "$tracked_scraped" ]]; then
  echo "pre-push: tracked files under data/raw/scraped are not allowed" >&2
  exit 1
fi

if git ls-files --error-unmatch 'outputs/*' >/dev/null 2>&1; then
  echo "pre-push: tracked files under outputs are not allowed" >&2
  exit 1
fi
